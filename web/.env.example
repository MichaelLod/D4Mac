# Stripe — secret key from dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me

# Ed25519 PKCS8 PEM — paste the full multi-line contents of
# keys/license-priv.pem here, between the quotes (literal newlines OK on
# Vercel; for local .env.local, escape as \n or use real newlines if your
# loader supports them).
LICENSE_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
MC4CAQAwBQYDK2VwBCIEIA_paste_real_key_contents_here
-----END PRIVATE KEY-----"

# Token gating /dashboard. Generate with `openssl rand -hex 24`.
# The dashboard returns 404 unless the URL has ?token=<this>.
DASHBOARD_TOKEN=replace_with_long_random_hex

# Postgres (Railway). Connection string from the Railway service's
# Connect tab. Used by the download counter and (later) license audit log.
# Optional: when unset, the counter renders as "—" but the rest of the
# site works.
DATABASE_URL=postgres://user:pass@host:port/dbname

# Public download URL for the latest D4Mac.dmg. Point this at a Railway
# Bucket presigned URL (90-day expiry) or any HTTPS URL serving the .dmg.
# When unset, /api/download returns 503.
D4MAC_RELEASE_URL=https://example.com/D4Mac-0.1.0.dmg
