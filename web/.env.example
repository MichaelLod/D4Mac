# Stripe — secret or restricted key from dashboard.stripe.com/apikeys.
# Use sk_test_ / rk_test_ locally; rk_live_ on Vercel production.
STRIPE_SECRET_KEY=sk_test_replace_me

# Token gating /dashboard. Generate with `openssl rand -hex 24`.
# The dashboard returns 404 unless the URL has ?token=<this>.
DASHBOARD_TOKEN=replace_with_long_random_hex
